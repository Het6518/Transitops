# ── Monorepo root .gitignore ──────────────────────────────────────────────────

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime / temp
.cache/
tmp/
temp/

# Optional: allow .env.example files to be committed
!.env.example

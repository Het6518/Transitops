# ── Backend .gitignore ────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
out/

# Environment variables (NEVER commit)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Prisma
prisma/migrations/dev.db
prisma/dev.db
prisma/*.db
prisma/*.db-journal

# Uploads & user-generated files
uploads/
tmp/
temp/

# TypeScript incremental compilation cache
*.tsbuildinfo
tsconfig.tsbuildinfo

# Testing
coverage/
.nyc_output/

# OS generated
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# ── Frontend .gitignore ───────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/
out/
.output/

# Environment variables (NEVER commit)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging
!.env.example

# Vite & dev tooling cache
.vite/
vite.config.ts.timestamp-*

# TypeScript incremental compilation cache
*.tsbuildinfo
tsconfig.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/

# OS generated
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Optional: shadcn/ui generated component registry (keep if you want)
# components.json
